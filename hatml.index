<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>كويز العربية - السنة الأولى متوسط</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(145deg, #1a472a 0%, #0e2a1a 100%);
            font-family: 'Segoe UI', 'Amiri', 'Tajawal', 'Cairo', system-ui, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .game-container {
            width: 100%;
            max-width: 800px;
            background: rgba(255, 248, 225, 0.95);
            border-radius: 64px 48px 64px 48px;
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.4), inset 0 1px 4px rgba(255, 255, 255, 0.6);
            overflow: hidden;
            backdrop-filter: blur(2px);
            transition: all 0.3s ease;
        }

        .islamic-header {
            background: linear-gradient(135deg, #2c5e2e, #1d3e1a);
            padding: 20px 15px 15px;
            text-align: center;
            border-bottom: 3px solid #ffd966;
        }

        .bismillah {
            font-size: 1.8rem;
            font-weight: bold;
            color: #ffefb9;
            text-shadow: 2px 2px 0 #3a2a0a;
            letter-spacing: 2px;
            font-family: 'Amiri', 'Traditional Arabic', serif;
        }

        .salawat {
            font-size: 1.2rem;
            color: #ffe1a0;
            margin-top: 8px;
            font-family: 'Amiri', serif;
            background: rgba(0,0,0,0.2);
            display: inline-block;
            padding: 4px 20px;
            border-radius: 40px;
            backdrop-filter: blur(2px);
        }

        .level-bar {
            background: #2e241f;
            padding: 12px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            color: #f9e7c2;
            font-weight: bold;
            border-bottom: 1px solid #cfb284;
        }

        .level-badge {
            background: #ffb347;
            padding: 5px 15px;
            border-radius: 40px;
            color: #2c1a0c;
            font-size: 1rem;
            box-shadow: inset 0 -1px 0 #c16f1a, 0 2px 6px rgba(0,0,0,0.2);
        }

        .score-area {
            background: #1f2a0e;
            padding: 5px 12px;
            border-radius: 30px;
            font-size: 1rem;
        }

        .timer-area {
            background: #0f2f1f;
            padding: 5px 12px;
            border-radius: 30px;
            font-family: monospace;
            font-size: 1.3rem;
            letter-spacing: 2px;
        }

        .quiz-card {
            padding: 30px 25px 20px;
            background: #fffcf0;
        }

        .question-text {
            font-size: 1.55rem;
            font-weight: bold;
            background: #fef3da;
            padding: 20px 18px;
            border-radius: 48px;
            margin-bottom: 30px;
            text-align: center;
            box-shadow: inset 0 0 0 2px #fff8e7, 0 8px 18px rgba(0,0,0,0.1);
            color: #2c4722;
            line-height: 1.4;
        }

        .options-grid {
            display: flex;
            flex-direction: column;
            gap: 14px;
            margin-bottom: 35px;
        }

        .option-btn {
            background: #e7e3d4;
            border: 2px solid #cbbf9a;
            border-radius: 60px;
            padding: 14px 20px;
            font-size: 1.1rem;
            font-weight: 500;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s ease;
            color: #2d3e1f;
            font-family: 'Cairo', sans-serif;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        .option-btn:hover:not(:disabled) {
            background: #d9cfae;
            transform: scale(0.98);
            border-color: #b68b40;
        }

        .option-btn.selected {
            background: #2b7a3e;
            border-color: #ffdd99;
            color: white;
            box-shadow: 0 0 0 2px #ffd966;
        }

        .option-btn.disabled-opt, .option-btn:disabled {
            opacity: 0.6;
            cursor: default;
        }

        .action-buttons {
            display: flex;
            justify-content: space-between;
            gap: 15px;
            margin-top: 10px;
            margin-bottom: 10px;
        }

        .btn {
            flex: 1;
            padding: 12px 10px;
            font-size: 1.1rem;
            font-weight: bold;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: 0.2s;
            font-family: inherit;
            background: #d9c5a7;
            color: #382812;
            box-shadow: 0 3px 0 #8b6946;
        }

        .btn-primary {
            background: #3f8b3c;
            color: white;
            box-shadow: 0 3px 0 #1d511a;
        }

        .btn-danger {
            background: #b54a3a;
            color: white;
            box-shadow: 0 3px 0 #712818;
        }

        .btn:active {
            transform: translateY(2px);
            box-shadow: 0 1px 0;
        }

        .feedback {
            text-align: center;
            margin-top: 20px;
            font-size: 1.2rem;
            font-weight: bold;
            padding: 10px;
            border-radius: 40px;
            background: #f0e9d8;
            color: #2b4920;
        }

        .completion-screen {
            text-align: center;
            padding: 40px 20px;
            background: #fff0db;
        }

        .hidden {
            display: none;
        }

        footer {
            background: #1e2c12;
            padding: 12px;
            text-align: center;
            color: #c7b28b;
            font-size: 0.85rem;
            border-top: 1px solid #c9aa6b;
        }

        .supervisor {
            font-weight: bold;
            color: #ffdfa5;
            background: #2c421e;
            padding: 8px;
            border-radius: 30px;
            margin: 5px 15px 10px;
            text-align: center;
            font-size: 0.9rem;
        }

        @media (max-width: 550px) {
            .question-text {
                font-size: 1.2rem;
            }
            .option-btn {
                font-size: 0.9rem;
                padding: 10px 12px;
            }
            .bismillah {
                font-size: 1.3rem;
            }
        }
    </style>
</head>
<body>
<div class="game-container" id="gameRoot">
    <div class="islamic-header">
        <div class="bismillah">بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ</div>
        <div class="salawat">اللهم صلِّ و سلِّم على سيدنا محمد</div>
    </div>
    <div id="dynamicContent">
        <!-- سيتم الملء بواسطة JS -->
    </div>
    <footer>
        <div>تحت إشراف مفتش مادة اللغة العربية <strong>هراڨمي سعد</strong> و الأستاذة <strong>يحياوي مروة</strong></div>
        <div style="font-size:0.75rem; margin-top:5px;">🎓 كويز التحدي - السنة الأولى متوسط | 5 مستويات مع توقيت</div>
    </footer>
</div>

<script>
    // ---------------------- الأسئلة الكاملة (58 سؤال) ----------------------
    const allQuestionsData = [
        // الضمير وأنواعه (10)
        { text: "الضّمير هو...", options: ["اسم يدلّ على حدث.", "كلمة تدلّ على من يتكلّم أو يخاطب أو يُتحدّث عنه.", "فعل يدلّ على الزّمن."], correct: 1 },
        { text: "حدّد الضّمير في الكلمات التّالية: المدرسة. جميل. هو.", options: ["المدرسة.", "جميل.", "هو."], correct: 2 },
        { text: "الضمير المتّصل يكون:", options: ["متّصلا بالاسم أو الفعل.", "حرفا.", "يأتي وحده."], correct: 0 },
        { text: "الضّمير 'كنتم' يتكوّن من:", options: ["اسم+ضمير.", "حرف+ضمير.", "فعل +ضمير."], correct: 2 },
        { text: "الضّمير 'إيّاك' هو ضمير:", options: ["متّصل.", "منفصل.", "غائب."], correct: 1 },
        { text: "حدّد الجملة التي تحتوي على ضمير منفصل:", options: ["فهمنا الدّرس.", "كتابي جديد.", "هو مجتهد."], correct: 2 },
        { text: "أعرب الضّمير 'أنا' في الجملة: أنا مجتهد.", options: ["فاعل.", "مبتدأ.", "مفعول به."], correct: 1 },
        { text: "أعرب 'هو' في الجملة: نجح هو في الامتحان.", options: ["مبتدأ.", "خبر.", "فاعل."], correct: 2 },
        { text: "الضّمير 'نحن' هو ضمير:", options: ["متّصل.", "متكلّم.", "مخاطب."], correct: 1 },
        { text: "الضّمير يستعمل من أجل:", options: ["اختصار الكلام.", "تكرار الكلام.", "حذف المعنى."], correct: 0 },
        // الفعل ودلالته الزمنية (10)
        { text: "الفعل هو...", options: ["اسم يدلّ على شيء.", "ضمير.", "كلمة تدلّ على حدث مقترن بزمن."], correct: 2 },
        { text: "حدّد الجملة التي تحتوي على فعل مضارع:", options: ["يقرأ القصّة.", "اقرأ الكتاب.", "كتب الدّرس."], correct: 0 },
        { text: "الفعل اكتب يدلّ على:", options: ["الماضي.", "الحاضر.", "الأمر."], correct: 2 },
        { text: "حدّد الفعل في الكلمات التّالية: مشرقة. في. قرأ.", options: ["مشرقة.", "في.", "قرأ."], correct: 2 },
        { text: "الفعل 'ذهب' يدلّ على:", options: ["الحاضر.", "الماضي.", "المستقبل."], correct: 1 },
        { text: "اذكر علامة الفعل الماضي:", options: ["يقبل تاء الفاعل.", "يقبل السّين.", "يقبل لم."], correct: 0 },
        { text: "حدّد دلالة الفعل 'سيسافر':", options: ["مستقبل.", "أمر.", "ماضي."], correct: 0 },
        { text: "الفعل المضارع غالباً ما يدلّ على:", options: ["حدث وقع في الماضي.", "حدث يحدث الآن أو مستمرّ.", "فعل طلب أو أمر."], correct: 1 },
        { text: "أعرب بكى في الجملة: بكى الطّفل", options: ["فعل ماض مبني على الفتحة الظاهرة.", "فعل أمر.", "فعل ماض مبني على الفتحة المقدّرة."], correct: 2 },
        { text: "أعرب 'قف' في الجملة: قف عند الباب", options: ["فعل أمر مبني على السكون.", "فعل ماض مبني على الفتحة.", "فعل ماض مبني على السكون."], correct: 0 },
        // النعت الحقيقي (8)
        { text: "أكمل ما يلي: النعت الحقيقي هو...", options: ["يصف الاسم ويطابقه تمامًا.", "كلمة تدلّ على الحدث.", "اسم علم."], correct: 0 },
        { text: "حدّد الأحكام التي تنطبق على النّعت الحقيقي:", options: ["يطابق المنعوت في العدد والجنس.", "يطابق المنعوت في الإعراب.", "كل ماسبق."], correct: 2 },
        { text: "اذكر الجملة التي تشتمل على نعت حقيقي:", options: ["جاء الطّالب.", "قرأت الكتاب المفيد.", "اكتب درسك."], correct: 1 },
        { text: "حدّد النّعت الحقيقي في: الحديقة الجميلة واسعةٌ:", options: ["الحديقة", "الجميلة", "واسعة"], correct: 1 },
        { text: "أكمل الجملة: رأيت الطالبتين... في الصّفِّ.", options: ["المجتهدتين.", "المجتهدتان.", "المجتهدة."], correct: 0 },
        { text: "أكمل الجملة: رأيت اللّوحة...", options: ["الجميلُ.", "الجميلةَ.", "الجميلَ."], correct: 1 },
        { text: "أعرب الكبيرة في الجملة: رأيت السيّارة الكبيرة.", options: ["مفعول به.", "نعت منصوب.", "خبر."], correct: 1 },
        { text: "أعرب الكسول في الجملة: التّلميذُ الكسولُ رسب في الامتحان.", options: ["نعت مرفوع.", "فاعل.", "خبر."], correct: 0 },
        // أسماء الإشارة (10)
        { text: "أكمل: أسماء الإشارة هي...", options: ["أسماء تدل على الزمان.", "أسماء تدل على المكان.", "أسماء نستخدمها للإشارة إلى شيء معيّن."], correct: 2 },
        { text: "نقول عن أسماء الإشارة أنها:", options: ["معربة دائما.", "مبنية دائما.", "أفعال."], correct: 1 },
        { text: "حدّد الجملة الصحيحة:", options: ["هؤلاء الكتاب مفيد.", "هذه القلم جديد.", "هذا التّلميذ مجتهد."], correct: 2 },
        { text: "(...) المنزل جميل.", options: ["هذا.", "هؤلاء.", "هذه."], correct: 0 },
        { text: "(...) الأقلام جديدة.", options: ["ذلك.", "هؤلاء.", "هذا."], correct: 1 },
        { text: "اذكر اسم الإشارة المناسب للمثنّى المذكّر القريب.", options: ["هذان.", "هتان.", "ذلك."], correct: 0 },
        { text: "اذكر اسم الإشارة المناسب للمثنّى المؤنّث القريب.", options: ["هذان.", "هتان.", "هؤلاء."], correct: 1 },
        { text: "حدّد اسم الإشارة المناسب للمفرد المذكّر البعيد.", options: ["هذا.", "هذه.", "ذلك."], correct: 2 },
        { text: "حدّد اسم الإشارة المناسب للجمع البعيد.", options: ["هؤلاء.", "أولئك.", "هذه."], correct: 1 },
        { text: "حدّد اسم الإشارة للمفرد المؤنّث القريب.", options: ["هذه.", "ذلك.", "أولئك."], correct: 0 },
        // الأسماء الموصولة (10)
        { text: "الاسم الموصول هو...", options: ["اسم يدلّ على زمان.", "اسم يربط بين جملتين.", "حرف من حروف الجر."], correct: 1 },
        { text: "الاسم الموصول يأتي بعده دائما...", options: ["اسم فاعل.", "نعت.", "جملة اسميّة أو فعليّة تسمّى صلة الموصول."], correct: 2 },
        { text: "حدّد الاسم الموصول في الجملة: نجح التلميذ الّذي اجتهد.", options: ["التلميذ.", "نجح.", "الّذي."], correct: 2 },
        { text: "اختر الجواب الصحيح: التّلميذان... تفوّقا مجتهدان.", options: ["اللّذان.", "الّذي.", "الّتي."], correct: 0 },
        { text: "حدّد الاسم الموصول الصحيح: شاهدت الفتيات... فُزْنَ بالجائزة.", options: ["الّذين.", "الّواتي.", "الّتي."], correct: 1 },
        { text: "حدّد الاسم الموصول المناسب للمذكّر الجمع.", options: ["الّذين.", "الّذي.", "الّواتي."], correct: 0 },
        { text: "اذكر الاسم الموصول المناسب للمؤنّث للمفرد.", options: ["اللّتان.", "الّواتي.", "الّتي."], correct: 2 },
        { text: "نقول عن الأسماء الموصولة أنّها...", options: ["معربة دائما.", "أفعال.", "مبنيّة دائما."], correct: 2 },
        { text: "أعرب 'الّذي' في الجملة: الّذي يجتهد ينجح.", options: ["اسم موصول مبني في محل رفع مبتدأ.", "فاعل.", "نعت."], correct: 0 },
        { text: "أعرب 'الّتي' في الجملة: شاهدت الّتي فازت بالجائزة.", options: ["خبر.", "فاعل.", "اسم موصول في محل نصب مفعول به."], correct: 2 },
        // همزة القطع (10)
        { text: "همزة القطع تنطق:", options: ["في الابتداء فقط.", "في الابتداء والوصل فقط.", "لا تنطق."], correct: 1 },
        { text: "حدّد الكلمة التي تحتوي على همزة قطع.", options: ["استعمل.", "أحمد.", "ابن."], correct: 1 },
        { text: "همزة القطع تكتب:", options: ["على الواو فقط.", "بدون همزة.", "فوق الألف أو تحته."], correct: 2 },
        { text: "همزة القطع تثبت:", options: ["في النطق والكتابة.", "في النطق فقط.", "لا تثبت."], correct: 0 },
        { text: "كل الأسماء التالية همزتها همزة قطع ماعدا:", options: ["ابراهيم.", "أمل.", "اسم."], correct: 2 },
        { text: "كلمة 'إلى' تحتوي على:", options: ["همزة وصل.", "همزة قطع.", "همزة متطرّفة."], correct: 1 },
        { text: "أيّ الكلمات التّالية همزتها ليست همزة قطع.", options: ["استمع.", "أو.", "إذا."], correct: 0 },
        { text: "حدّد الكلمة الصّحيحة.", options: ["اكرم.", "أكرم.", "اكرام."], correct: 1 },
        { text: "الفعل الرّباعي 'أرسل' يبدأ ب:", options: ["بدون همزة.", "همزة متوسّطة.", "همزة قطع."], correct: 2 },
        { text: "همزة القطع في كلمة 'إسلام':", options: ["تنطق دائما.", "لا تنطق.", "تحذف."], correct: 0 }
    ];

    // تقسيم المستويات (5 مستويات)
    const totalQ = allQuestionsData.length;
    const perLevel = Math.ceil(totalQ / 5); // 12
    let levels = [];
    for (let i = 0; i < totalQ; i += perLevel) {
        levels.push(allQuestionsData.slice(i, i + perLevel));
    }
    while (levels.length < 5) levels.push([]);
    if (levels.length > 5) levels[4] = levels[4].concat(levels[5]), levels.pop();

    // متغيرات اللعبة
    let currentLevel = 0;
    let currentQIndex = 0;
    let levelQuestions = [];
    let scorePerLevel = 0;
    let totalScore = 0;
    let selectedOption = null;
    let timerInterval = null;
    let timeLeft = 15;
    let answeringLock = false;
    let nextQuestionTimeout = null;
    let currentAudioCtx = null;

    function playSound(isCorrect) {
        try {
            if (currentAudioCtx && currentAudioCtx.state !== 'closed') currentAudioCtx.close();
            const AudioContextClass = window.AudioContext || window.webkitAudioContext;
            const audioCtx = new AudioContextClass();
            currentAudioCtx = audioCtx;
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            oscillator.type = 'sine';
            oscillator.frequency.value = isCorrect ? 880 : 440;
            gainNode.gain.value = 0.3;
            oscillator.start();
            gainNode.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + 0.6);
            oscillator.stop(audioCtx.currentTime + 0.6);
        } catch(e) { console.log("صوت غير مدعوم"); }
    }

    function stopTimer() {
        if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
    }

    function updateTimerDisplay() {
        const timerSpan = document.getElementById("timerValue");
        if (timerSpan) timerSpan.innerText = timeLeft;
        if (timeLeft <= 0 && !answeringLock) {
            stopTimer();
            answeringLock = true;
            playSound(false);
            showFeedback("⏰ انتهى الوقت! الإجابة خاطئة.", false);
            disableOptions(true);
            if (nextQuestionTimeout) clearTimeout(nextQuestionTimeout);
            nextQuestionTimeout = setTimeout(() => moveToNextQuestion(), 1300);
        }
    }

    function startTimer() {
        stopTimer();
        timeLeft = 15;
        updateTimerDisplay();
        timerInterval = setInterval(() => {
            if (!answeringLock) {
                timeLeft--;
                updateTimerDisplay();
                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    timerInterval = null;
                    if (!answeringLock) updateTimerDisplay();
                }
            }
        }, 1000);
    }

    function disableOptions(disabled) {
        document.querySelectorAll('.option-btn').forEach(btn => btn.disabled = disabled);
    }

    function showFeedback(msg, isCorrect) {
        const feedbackDiv = document.getElementById("feedbackMsg");
        if (feedbackDiv) {
            feedbackDiv.innerHTML = msg;
            feedbackDiv.style.background = isCorrect ? "#c8e6c9" : "#ffcdd2";
            feedbackDiv.style.color = isCorrect ? "#1f4f1a" : "#8b2c1d";
        }
    }

    function clearFeedback() {
        const feedbackDiv = document.getElementById("feedbackMsg");
        if (feedbackDiv) {
            feedbackDiv.innerHTML = "⚡ اختر إجابة و اضغط تأكيد ⚡";
            feedbackDiv.style.background = "#f0e9d8";
            feedbackDiv.style.color = "#2b4920";
        }
    }

    function loadQuestion() {
        if (nextQuestionTimeout) clearTimeout(nextQuestionTimeout);
        answeringLock = false;
        selectedOption = null;
        clearFeedback();
        const qData = levelQuestions[currentQIndex];
        if (!qData) return;
        document.getElementById("questionText").innerText = qData.text;
        const optsContainer = document.getElementById("optionsContainer");
        optsContainer.innerHTML = "";
        qData.options.forEach((opt, idx) => {
            const btn = document.createElement("div");
            btn.className = "option-btn";
            btn.innerText = opt;
            btn.dataset.idx = idx;
            btn.onclick = () => {
                if (answeringLock) return;
                if (selectedOption !== null) document.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
                selectedOption = idx;
                btn.classList.add('selected');
            };
            optsContainer.appendChild(btn);
        });
        disableOptions(false);
        stopTimer();
        startTimer();
        document.getElementById("questionCounter").innerText = `${currentQIndex+1} / ${levelQuestions.length}`;
    }

    function confirmAnswer() {
        if (answeringLock) {
            showFeedback("تمت الإجابة بالفعل أو انتهى الوقت!", false);
            return;
        }
        if (selectedOption === null) {
            showFeedback("❌ يرجى اختيار إجابة أولاً!", false);
            playSound(false);
            return;
        }
        const currentQ = levelQuestions[currentQIndex];
        const isCorrect = (selectedOption === currentQ.correct);
        stopTimer();
        answeringLock = true;
        if (isCorrect) {
            scorePerLevel++;
            totalScore++;
            showFeedback("✅ إجابة صحيحة! أحسنت.", true);
            playSound(true);
        } else {
            const correctAnswerText = currentQ.options[currentQ.correct];
            showFeedback(`❌ خطأ! الإجابة الصحيحة: ${correctAnswerText}`, false);
            playSound(false);
        }
        disableOptions(true);
        if (nextQuestionTimeout) clearTimeout(nextQuestionTimeout);
        nextQuestionTimeout = setTimeout(() => moveToNextQuestion(), 1200);
    }

    function moveToNextQuestion() {
        if (currentQIndex + 1 < levelQuestions.length) {
            currentQIndex++;
            loadQuestion();
        } else {
            finishLevel();
        }
    }

    function finishLevel() {
        stopTimer();
        const totalLevelQ = levelQuestions.length;
        const earned = scorePerLevel;
        if (currentLevel + 1 < levels.length && levels[currentLevel+1] && levels[currentLevel+1].length > 0) {
            alert(`🎉 أكملت المستوى ${currentLevel+1} 🎉\nنقاطك: ${earned}/${totalLevelQ}\nانتقل إلى المستوى التالي!`);
            currentLevel++;
            currentQIndex = 0;
            scorePerLevel = 0;
            levelQuestions = [...levels[currentLevel]];
            updateLevelUI();
            loadQuestion();
        } else {
            const finalTotal = totalScore;
            const maxPossible = allQuestionsData.length;
            document.getElementById("dynamicContent").innerHTML = `
                <div class="completion-screen">
                    <h2 style="color:#2d6a2b;">🏆 هنيئاً 🏆</h2>
                    <p style="font-size:1.8rem; margin:20px 0;">لقد أكملت جميع المستويات الخمسة!</p>
                    <p style="font-size:1.5rem; background:gold; display:inline-block; padding:10px 30px; border-radius:60px;">إجمالي النقاط: ${finalTotal} / ${maxPossible}</p>
                    <div style="margin-top:30px;">
                        <button id="restartGameBtn" class="btn btn-primary" style="background:#2e7d32;">🔄 لعب من جديد</button>
                        <button id="exitGameBtnFinal" class="btn btn-danger" style="background:#8b3c2a;">🚪 خروج</button>
                    </div>
                </div>
            `;
            document.getElementById("restartGameBtn")?.addEventListener("click", () => location.reload());
            document.getElementById("exitGameBtnFinal")?.addEventListener("click", () => {
                if(confirm("هل تريد الخروج من اللعبة؟")) window.close?.() || alert("يمكنك إغلاق الصفحة.");
            });
            return;
        }
    }

    function updateLevelUI() {
        document.getElementById("levelNum").innerText = `${currentLevel+1} / 5`;
        document.getElementById("totalScoreSpan").innerText = `${totalScore}`;
        document.getElementById("levelProgress").innerText = `نقاط المستوى: ${scorePerLevel}/${levelQuestions.length}`;
    }

    function refreshUIAfterScore() {
        document.getElementById("totalScoreSpan").innerText = totalScore;
        document.getElementById("levelProgress").innerText = `نقاط المستوى: ${scorePerLevel}/${levelQuestions.length}`;
    }

    function initGame() {
        currentLevel = 0;
        currentQIndex = 0;
        totalScore = 0;
        scorePerLevel = 0;
        levelQuestions = [...levels[0]];
        const htmlMain = `
            <div class="level-bar">
                <div class="level-badge">⭐ المستوى <span id="levelNum">1 / 5</span> ⭐</div>
                <div class="score-area">🏅 مجموع النقاط: <span id="totalScoreSpan">0</span></div>
                <div class="timer-area">⏱️ <span id="timerValue">15</span> ث</div>
            </div>
            <div class="quiz-card">
                <div class="question-text" id="questionText"></div>
                <div class="options-grid" id="optionsContainer"></div>
                <div class="action-buttons">
                    <button class="btn btn-primary" id="confirmBtn">✔ تأكيد الإجابة</button>
                    <button class="btn btn-danger" id="exitGameBtn">🚪 خروج من اللعبة</button>
                </div>
                <div class="feedback" id="feedbackMsg">⚡ اختر إجابة و اضغط تأكيد ⚡</div>
                <div style="display: flex; justify-content: space-between; margin-top: 15px;">
                    <span id="questionCounter">1 / ${levelQuestions.length}</span>
                    <span id="levelProgress">نقاط المستوى: 0/${levelQuestions.length}</span>
                </div>
            </div>
        `;
        document.getElementById("dynamicContent").innerHTML = htmlMain;
        updateLevelUI();
        loadQuestion();
        document.getElementById("confirmBtn").addEventListener("click", confirmAnswer);
        document.getElementById("exitGameBtn").addEventListener("click", () => {
            if(confirm("هل تريد الخروج من اللعبة؟ سيتم فقد التقدم.")) location.reload();
        });
        const intervalUpdate = setInterval(() => {
            if (document.getElementById("totalScoreSpan")) {
                document.getElementById("totalScoreSpan").innerText = totalScore;
                document.getElementById("levelProgress").innerText = `نقاط المستوى: ${scorePerLevel}/${levelQuestions.length}`;
            } else clearInterval(intervalUpdate);
        }, 200);
    }

    initGame();
</script>
</body>
</html>
